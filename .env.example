# Stock Analysis Agent Configuration
# Copy this file to .env and fill in your values

# Ollama Configuration
# Ollama runs on Windows, accessible from WSL via 127.0.0.1:11434
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b

# WhatsApp Configuration (Twilio)
# Get these from https://www.twilio.com/console
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# WhatsApp Recipient
WHATSAPP_NUMBER=6587533570

# Enable WhatsApp Sending
# Set to 'true' to send WhatsApp messages, 'false' to disable
ENABLE_WHATSAPP_SEND=false

# Tavily API Configuration (Optional, for market news)
# Get API key from https://www.tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# Request Configuration
REQUEST_TIMEOUT_SECONDS=30
SYMBOL_PAUSE_SECONDS=3
MAX_TAVILY_RESULTS=3
